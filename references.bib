	pmid = {24029393},
	note = {Publisher: American Journal of Neuroradiology
Section: Review Articles},
	pages = {1849--1857},
	file = {Full Text PDF:C\:\\Users\\vince\\Zotero\\storage\\UF9CP6AK\\Xiang et al. - 2014 - CFD Computational Fluid Dynamics or Confounding F.pdf:application/pdf},
}

